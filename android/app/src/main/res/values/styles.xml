<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Medtrack" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:statusBarColor">#F7F9FC</item>
        <!-- Match the app surface so the floating bottom bar sits on one
             continuous background instead of a white system-nav strip. -->
        <item name="android:navigationBarColor">#F4F6FA</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>
</resources>
